# ============================================================================
# CureFound -- environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in values before running the stack:
#     cp .env.example .env
#
# `.env` is .gitignored at the repo root. `.env.example` IS committed and
# documents every field consumed by `app/core/config.py::Settings`.
#
# Fields are grouped by layer. Dev-safe defaults are provided where
# meaningful; secrets are left blank so a missed copy fails loudly at
# startup rather than silently running with a weak default.
# ============================================================================


# --- Runtime --------------------------------------------------------------
# One of: local | staging | production
# "local" relaxes several guards: docs are exposed, default secrets are
# tolerated, CORS is permissive. Any other value rejects placeholder
# credentials and hides /docs.
ENVIRONMENT=local

# Shown in /docs + OpenAPI.
PROJECT_NAME=CureFound
API_V1_STR=/api/v1

# Log verbosity for structlog. One of: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO


# --- CORS -----------------------------------------------------------------
# Comma-separated list of origins allowed to hit the API. For local dev
# the built-in UI is served from the same origin, but this lets a
# standalone frontend (e.g. Vite on :5173) call the backend without
# the browser blocking it.
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://localhost:8000


# --- KG backend -----------------------------------------------------------
# Which store backs the /kg, /repurpose, /diagnose endpoints.
#   networkx -- loads data/seed/kg.json into memory at startup. Default
#               for the hardened MVP; no external service required.
#   neo4j    -- talks Bolt to the service defined below. Required from
#               Phase 1 onward once ingestors have populated the DB.
KG_BACKEND=networkx


# --- Neo4j ----------------------------------------------------------------
# Only consumed when KG_BACKEND=neo4j (or when admin/ingest tools point at
# Neo4j explicitly). The Docker Compose service publishes bolt on 7687
# and the browser on 7474.
#
# SECURITY: the placeholder password MUST be changed if ENVIRONMENT != local.
# `Settings` refuses to boot otherwise.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changethis_dev_only
NEO4J_DATABASE=neo4j

# Memory cap for the Neo4j JVM. Keep at 2G for a 16 GB laptop; raise to
# 4G+ when ingesting the full PrimeKG graph (~4M edges) if your host has
# the headroom.
NEO4J_HEAP_MAX=2G


# --- Data paths -----------------------------------------------------------
# All paths are resolved relative to the `curefound/` project root unless
# absolute. Leave blank to accept the baked-in default from
# `app/core/paths.py`.
#
# DATA_DIR       -- parent of raw/, seed/, artifacts/
# SEED_KG_PATH   -- canonical seed KG (tracked in git for reproducibility)
# ARTIFACTS_DIR  -- TransE .npz + eval_report.json (tracked)
# RAW_DIR        -- Phase 1 downloads (gitignored; NOT redistributed)
DATA_DIR=data
SEED_KG_PATH=data/seed/kg.json
ARTIFACTS_DIR=data/artifacts
RAW_DIR=data/raw


# --- TransE ---------------------------------------------------------------
# Training hyperparameters consumed by `app.ml.transe`. Defaults match
# the checked-in artifact (MRR 0.131 leave-one-out, n=16). Override only
# when experimenting.
TRANSE_DIM=64
TRANSE_EPOCHS=400
TRANSE_LR=0.01
TRANSE_MARGIN=1.0
TRANSE_NEGATIVE_SAMPLES=10
TRANSE_SEED=42


# --- Phase 1 ingest sources ----------------------------------------------
# Per-source toggles for `app.etl.fetch_all` and the Ingestor ABC's
# checkpoint store. All default ON; flip to 0 to skip while debugging.
INGEST_PRIMEKG=1
INGEST_DRUGCENTRAL=1
INGEST_HPO=1
INGEST_ORPHANET=1
INGEST_REACTOME=1

# DrugCentral ships as a Postgres dump. If you prefer the CSV slice
# (distributed by the same group) set this to `csv`. Default is `pg_dump`.
DRUGCENTRAL_FORMAT=pg_dump

# Harvard Dataverse token -- optional; speeds up large PrimeKG downloads
# and avoids rate limits. Get one at https://dataverse.harvard.edu
DATAVERSE_API_TOKEN=


# --- Disease scope --------------------------------------------------------
# Scope for the Phase 1 induced subgraph + all downstream evaluation.
# Values:
#   lsd          -- LSD focus (~50-80 diseases; default for FYP)
#   lsd_extended -- LSD + neurodegeneration neighbours (~150 diseases)
#   all          -- no scope filter (the full PrimeKG graph; >20k diseases)
DISEASE_SCOPE=lsd


# --- Server ---------------------------------------------------------------
# Uvicorn bind settings consumed by `run.py serve` and the Docker
# backend container. Keep 0.0.0.0 in container; 127.0.0.1 is fine
# locally if you don't want the port exposed on your LAN.
HOST=0.0.0.0
PORT=8000
RELOAD=1       # hot reload during dev; set 0 in production / Docker
