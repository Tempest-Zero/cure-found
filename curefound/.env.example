# ============================================================================
# CureFound -- environment configuration template
#
# Usage:
#   cp .env.example .env       # then edit values; .env is git-ignored
#
# pydantic-settings reads .env at startup. Variable names below match the
# `Settings` fields in `app/core/config.py` exactly.
# ============================================================================

# --- Environment & meta ----------------------------------------------------
# `local` enables /docs and looser validators; anything else hides /docs and
# turns on production-mode safety checks.
ENVIRONMENT=local
PROJECT_NAME=CureFound

# Mounted under /api/v1/* in addition to the legacy unprefixed routes.
API_V1_STR=/api/v1

# --- CORS ------------------------------------------------------------------
# Comma-separated list of allowed origins. Default covers local Vite dev
# (5173) and the FastAPI server itself (8000).
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# --- KG backend ------------------------------------------------------------
# Single in-process NetworkX backend. The Neo4j path was removed during
# cleanup; restore from git history if you ever need it.
KG_BACKEND=networkx

# --- Data paths (relative to project root) ---------------------------------
DATA_DIR=data
SEED_KG_PATH=data/seed/kg.json
ARTIFACTS_DIR=data/artifacts
RAW_DIR=data/raw

# --- Disease scope ---------------------------------------------------------
# `lsd` = the 13 lysosomal storage disorders the seed KG was built around.
DISEASE_SCOPE=lsd

# --- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=true

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
